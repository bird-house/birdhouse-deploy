export S3_VERSION=v1.3.1
export S3_VERSION_SEMVER='${S3_VERSION#v}'
export S3_DOCKER=versity/versitygw
export S3_IMAGE='${S3_DOCKER}:${S3_VERSION}'
export S3_IMAGE_URI='registry.hub.docker.com/${S3_IMAGE}'

export S3_CLI_VERSION=2.34.3
export S3_CLI_DOCKER=amazon/aws-cli
export S3_CLI_IMAGE='${S3_CLI_DOCKER}:${S3_CLI_VERSION}'

# S3 uses object storage on disk at this location
export S3_DATA_STORE='${BIRDHOUSE_DATA_PERSIST_ROOT}/s3_data/'

# S3 credentials
export __DEFAULT__S3_ROOT_ACCESS_KEY=S3admin
export __DEFAULT__S3_ROOT_SECRET_KEY=S3adminsecret
export S3_ROOT_ACCESS_KEY="${__DEFAULT__S3_ROOT_ACCESS_KEY}"
export S3_ROOT_SECRET_KEY="${__DEFAULT__S3_ROOT_SECRET_KEY}"

export DELAYED_EVAL="
  $DELAYED_EVAL
  S3_IMAGE
  S3_IMAGE_URI
  S3_CLI_IMAGE
  S3_DATA_STORE
  S3_VERSION_SEMVER
"

# S3_ROOT_ACCESS_KEY and S3_ROOT_SECRET_KEY are set as VARS so that the check_default_vars function will raise an warning if the default values are used.
export VARS="
  $VARS
  \$S3_ROOT_ACCESS_KEY
  \$S3_ROOT_SECRET_KEY
  \$S3_VERSION_SEMVER
  \$S3_IMAGE_URI
"
