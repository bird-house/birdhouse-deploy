# All env in this default.env can be overridden by env.local.

# thredds-docker >= 4.6.18 or >= 5.2 strongly recommended to avoid Log4J CVE-2021-44228.
export THREDDS_TAGGED="5.5-unidata-2024-11-19-with-tds-plugin-jar-with-dependencies.jar"
export THREDDS_VERSION="5.5.0-unidata-2024-11-19"
export THREDDS_DOCKER=pavics/thredds-docker
export THREDDS_IMAGE='${THREDDS_DOCKER}:${THREDDS_TAGGED}'
export THREDDS_IMAGE_URI='registry.hub.docker.com/${THREDDS_IMAGE}'

export THREDDS_ORGANIZATION='${BIRDHOUSE_INSTITUTION}'
export THREDDS_ORGANIZATION_WEBSITE='${BIRDHOUSE_DOC_URL}'
export THREDDS_ORGANIZATION_LOGO_URL=""
export THREDDS_SUPPORT_ORGANIZATION='${THREDDS_ORGANIZATION}'
export THREDDS_SUPPORT_EMAIL='${BIRDHOUSE_SUPPORT_EMAIL}'
export THREDDS_SUPPORT_PHONE=""
export THREDDS_ABSTRACT="Scientific Climate Data"
export THREDDS_KEYWORDS="meteorology, atmosphere, climate, ocean, earth science, birdhouse"

export THREDDS_ADDITIONAL_CATALOG=""

export THREDDS_DATASET_LOCATION_ON_CONTAINER='/birdhouse-ncml'
export THREDDS_SERVICE_DATA_LOCATION_ON_CONTAINER='/birdhouse-data'
export THREDDS_DATASET_LOCATION_ON_HOST='${BIRDHOUSE_DATA_PERSIST_ROOT}/ncml'
export THREDDS_SERVICE_DATA_LOCATION_ON_HOST='${BIRDHOUSE_DATA_PERSIST_ROOT}/datasets'
export THREDDS_DATASET_LOCATION_NAME='Datasets'
export THREDDS_SERVICE_DATA_LOCATION_NAME='Birdhouse'
export THREDDS_DATASET_URL_PATH='datasets'
export THREDDS_SERVICE_DATA_URL_PATH='birdhouse'

export THREDDS_MAGPIE_EXTRA_METADATA_PREFIXES='".+\\.txt", ".+\\.md", ".+\\.rst"'
export THREDDS_MAGPIE_EXTRA_DATA_PREFIXES=''

export THREDDS_SERVICE_DATA_EXTRA_FILE_FILTERS=''

export THREDDS_DATASET_DATASETSCAN_BODY='
      <metadata inherited="true">
        <serviceName>all</serviceName>
      </metadata>

      <filter>
        <include wildcard="*.nc" />
        <include wildcard="*.ncml" />
        <include wildcard="*.txt" />
        <include wildcard="*.md" />
        <include wildcard="*.rst" />
        <include wildcard="*.csv" />
      </filter>
'

# The minimum and maximum Java heap space memory to be allocated to the TDS
export THREDDS_XMX_SIZE=20G
export THREDDS_XMS_SIZE=1G

# TDM related environment variables
export THREDDS_TDM_PW=CHANGEME!
export THREDDS_TDS_HOST=http://thredds.yourhost.net/
# The minimum and maximum Java heap space memory to be allocated to the TDM
export THREDDS_TDM_XMX_SIZE=12G
export THREDDS_TDM_XMS_SIZE=1G

# TDS Content root
export THREDDS_TDS_CONTENT_ROOT_PATH=/usr/local/tomcat/content

# See https://github.com/Unidata/tomcat-docker#configurable-tomcat-uid-and-gid
export THREDDS_TOMCAT_USER_ID=1000
export THREDDS_TOMCAT_GROUP_ID=1000

# By default, netCDF-Java will encode illegal URI characters using percent
# encoding (e.g. [ will become %5B). If you find you are having trouble
# accessing a remote dataset due to the encoding, set the java System Property
# httpservices.urlencode to "false" using, for example
# System.setProperty("httpservices.urlencode", "false");.
# https://www.unidata.ucar.edu/software/netcdf-java/current/reference/DatasetUrls.html
#export THREDDS_CATALINA_OPTS="-Dhttpservices.urlencode=false"
export THREDDS_CATALINA_OPTS=""

# Extra content for threddsConfig.xml
# Example to increase OpenDap binary response size to avoid chunking for small datasets
# (should also increase THREDDS_XMX_SIZE appropriately).
#export THREDDS_CONFIG_XML_EXTRA="
#  <Opendap>
#  <!-- https://docs.unidata.ucar.edu/tds/current/userguide/tds_config_ref.html#opendap-service -->
#  <!-- binLimit: maximum size of a binary data response, in Megabytes. Default is 500 Mbytes. -->
#  <binLimit>2000</binLimit>
#  </Opendap>
#"
export THREDDS_CONFIG_XML_EXTRA=""


# add any new variables not already in 'VARS' or 'OPTIONAL_VARS' that must be replaced in templates here
VARS="
  $VARS
  \$THREDDS_SERVICE_DATA_LOCATION_NAME
  \$THREDDS_SERVICE_DATA_URL_PATH
  \$THREDDS_SERVICE_DATA_LOCATION_ON_CONTAINER
  \$THREDDS_DATASET_LOCATION_NAME
  \$THREDDS_DATASET_URL_PATH
  \$THREDDS_DATASET_LOCATION_ON_CONTAINER
  \$THREDDS_DATASET_DATASETSCAN_BODY
"

OPTIONAL_VARS="
  $OPTIONAL_VARS
  \$BIRDHOUSE_INSTITUTION
  \$BIRDHOUSE_DOC_URL
  \$BIRDHOUSE_SUPPORT_EMAIL
  \$THREDDS_ABSTRACT
  \$THREDDS_KEYWORDS
  \$THREDDS_ORGANIZATION
  \$THREDDS_ORGANIZATION_WEBSITE
  \$THREDDS_ORGANIZATION_LOGO_URL
  \$THREDDS_SUPPORT_ORGANIZATION
  \$THREDDS_SUPPORT_EMAIL
  \$THREDDS_SUPPORT_PHONE
  \$TWITCHER_PROTECTED_PATH
  \$THREDDS_DOCKER
  \$THREDDS_TAGGED
  \$THREDDS_VERSION
  \$THREDDS_IMAGE
  \$THREDDS_IMAGE_URI
  \$THREDDS_ADDITIONAL_CATALOG
  \$THREDDS_SERVICE_DATA_EXTRA_FILE_FILTERS
  \$THREDDS_MAGPIE_EXTRA_METADATA_PREFIXES
  \$THREDDS_MAGPIE_EXTRA_DATA_PREFIXES
  \$THREDDS_CONFIG_XML_EXTRA
"

export DELAYED_EVAL="
  $DELAYED_EVAL
  THREDDS_ORGANIZATION
  THREDDS_ORGANIZATION_WEBSITE
  THREDDS_SUPPORT_ORGANIZATION
  THREDDS_SUPPORT_EMAIL
  THREDDS_SUPPORT_PHONE
  THREDDS_DATASET_LOCATION_ON_HOST
  THREDDS_SERVICE_DATA_LOCATION_ON_HOST
  THREDDS_IMAGE
  THREDDS_IMAGE_URI
"
